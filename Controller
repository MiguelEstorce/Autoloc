	//---------------------------------------------------------------------------------------------------------------------------
	
	protected void listarAnuncios(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		ArrayList<JavaBeans> lista = dao.listarAnuncio();  //DAO
		
