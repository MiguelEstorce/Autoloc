package controller;

import java.io.IOException;
import java.util.ArrayList;

import jakarta.servlet.RequestDispatcher;
import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import model.DAO;
import model.JavaBeans;

/**
 * Servlet implementation class Controller
 */
@WebServlet({"/cadastro","/deletar","/edit","navegacao","/cadastrou","/cadastrol","/loginu","/loginl","/update"})
public class Controller extends HttpServlet {
	private static final long serialVersionUID = 1L;
       
	DAO dao = new DAO();
	/**
	 * @see HttpServlet#doGet(HttpServletRequest request, HttpServletResponse response)
	 */
	protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		// TODO Auto-generated method stub
		response.getWriter().append("Served at: ").append(request.getContextPath());
		
		 String action = request.getServletPath();
	        
	        System.out.println("ACTION: " + request.getServletPath());

	        if(action.equals("/")) {
	           
	        } 
	        else if(action.equals("/cadastrou")) { //cadastro do usuario
	             cadastrarUsuario(request, response);
	        } 
	        else if(action.equals("/cadastrol")) { //cadastro do lojista
	             cadastrarLojista(request, response);
	        } 
	        else if(action.equals("/loginu")) { //login do usuario
	             loginUsuario(request, response);
	        } 
	        else if(action.equals("/loginl")) { //login do lojista
	             loginLojista(request, response);
	        } 
	        else if(action.equals("/deletar")) {
	        	deletarAnuncio(request, response);
	        }
	        else if(action.equals("/edit")) {
	        	editarAnuncio(request, response);
	         }
	        else if(action.equals("/navegacao")) {
	        	listarAnuncios(request, response);
	         }
	        else if(action.equals("/")) {
	        	buscarAnuncioRemover(request, response);
	         }
	        else if(action.equals("/")) {
	        	buscarAnuncioEditar(request, response);
	        	
	         }
	        else if(action.equals("/")) {
	        	
	         }
	        else
	        {
	            response.sendRedirect("/"); //voltar para pagina inicial
	        }
		
	}

	/**
	 * @see HttpServlet#doPost(HttpServletRequest request, HttpServletResponse response)
	 */
	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		String acao = request.getParameter("acao");
		String tipo = request.getParameter("tipo");
		String action = request.getServletPath();
		
		  if(action.equals("/cadastro")) {
	        	inserirAnuncio(request, response);
	            
	        } else if(action.equals("/update")) {
	        	atualizarAnuncio(request, response);
	        }
		
		//-----------------------------------------------------------------------------------------------  
		if (acao.equals("login")) {
			
			 if (tipo.equals("usuario")) {
				 loginUsuario(request, response);
			 } 
			 else if (tipo.equals("lojista")) {
				 loginLojista(request, response);
			 }
		} else if (acao.equals("cadastrar")) {
			
			if (tipo.equals("usuario")) {
				cadastrarUsuario(request, response);
			}
			else if (tipo.equals("lojista")) {
				cadastrarLojista(request, response);
			}
		}
		
		//doGet(request, response);
	}
	
	//-------------------------------CADASTRO----USUARIO--------------------------------------------------------------------------
	
	protected void cadastrarUsuario(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans cdu = new JavaBeans();  //cdu é uma variavel qualquer
		
		String nome = request.getParameter("nome");
		String cpf = request.getParameter("cpf");
		String email = request.getParameter("email");
		String senha = request.getParameter("senha");
		String numeroTelefone = request.getParameter("numeroTelefone");
		
		// Remove pontos e traços do CPF
	    cpf = cpf.replace(".", "").replace("-", "");
	    
	    cdu.setNome(nome);
	    cdu.setCpf(cpf);
		cdu.setEmail(email);
		cdu.setSenha(senha);
		cdu.setNumeroTelefone(numeroTelefone);
		
		//salvamento da tabela CADASTRO USUARIO
		cdu.setTipoUsuario("usuario");
		dao.cadastrarUsuario(cdu);  	//Tem que ter no DAO 
		
		response.sendRedirect("loginUsuario.jsp"); //Tela de CADASTRO DO USUARIO
	}
	
	//-------------------------------CADASTRAR----LOJISTA-------------------------------------------------------------------------
	
	protected void cadastrarLojista(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans cdl = new JavaBeans();
		
		String nomeEmpresa = request.getParameter("nomeEmpresa");
		String nome = request.getParameter("nome");
		String cpf = request.getParameter("cpf");
		String cnpj = request.getParameter("cnpj");
		String cep = request.getParameter("cep");
		String endereco = request.getParameter("endereco");
		String numeroTelefone = request.getParameter("numeroTelefone");
		String email = request.getParameter("email");
		String senha = request.getParameter("senha");
		
		cpf = cpf.replace(".", "").replace("-", "");
		cnpj = cnpj.replace(".", "").replace("/", "").replace("-","");
		
		cdl.setNomeEmpresa(nomeEmpresa);
		cdl.setNome(nome);
		cdl.setCpf(cpf);
		cdl.setCnpj(cnpj);
		cdl.setCep(cep);
		cdl.setEndereco(endereco);
		cdl.setNumeroTelefone(numeroTelefone);
		cdl.setEmail(email);
		cdl.setSenha(senha);
		
		dao.cadastrarLojista(cdl);        //tem que ter o DAO
		
		response.sendRedirect("loginLojista"); //Tela de cadastro do LOJISTA
	}
	
	//-------------------------------LOGIN----USUARIO-----------------------------------------------------------------------------
	
	protected void loginUsuario(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans lgu = new JavaBeans();
		
		String email = request.getParameter("email");
		String senha = request.getParameter("senha");
		
		lgu.setEmail(email);
		lgu.setSenha(senha);
				
		boolean autenticado = dao.loginUsuario(lgu);
		
		if (autenticado) {
			response.sendRedirect(""); //Colocar Tela Inicial
		} else {
			response.sendRedirect("loginUsuario.jsp?erro=1");
		}
	}
	
	//-------------------------------LGIN----LOJISTA------------------------------------------------------------------------------
	
	protected void loginLojista(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans lgl = new JavaBeans();
		
		String cnpj = request.getParameter("cnpj");
		String email = request.getParameter("email");
		String senha = request.getParameter("senha");
		
		lgl.setCnpj(cnpj);
		lgl.setEmail(email);
		lgl.setSenha(senha);
		
		boolean autenticado = dao.loginLojista(lgl);
		
		if (autenticado) {
			response.sendRedirect(""); //Colocar Tela Inicial
		} else {
			response.sendRedirect("loginLojista.jsp?erro=1");
		}
		
		
	}
	
	//-------------------------------INSERIR----ANUNCIO---------------------------------------------------------------------------
	
	protected void inserirAnuncio(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans anuncio = new JavaBeans();
		
		String nome = request.getParameter("nome");
		String modelo = request.getParameter("modelo");
		String marca = request.getParameter("marca");
		String carroceria = request.getParameter("carroceria");
		String descricao = request.getParameter("descricao");
		String ano = request.getParameter("ano");
		String kilometragem = request.getParameter("kilometragem");
		String preco = request.getParameter("preco");
		String imagem = request.getParameter("imagem");
		
		anuncio.setNome(nome);
		anuncio.setModelo(modelo);
		anuncio.setMarca(marca);
		anuncio.setCarroceria(carroceria);
		anuncio.setDescricao(descricao);
		anuncio.setAno(Integer.parseInt(ano));
		anuncio.setKilometragem(Integer.parseInt(kilometragem));
		anuncio.setPreco(Double.parseDouble(preco));
		anuncio.setImagem(imagem);
		
		dao.inserirAnuncios(anuncio); //requer o dao
		
		response.sendRedirect(""); //Ir para tela inicial
		
	}
	
	//-------------------------------DELETAR----ANUNCIO---------------------------------------------------------------------------
	
	protected void deletarAnuncio(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans anuncio = new JavaBeans();
		
		anuncio.setIdcon(request.getParameter("id"));
		dao.deletarAnuncio(anuncio); //DAO
		
		response.sendRedirect(""); //DAO
		
	}

	//-------------------------------BUSCAR----PARA----REMOVER--------------------------------------------------------------------
	
	protected void buscarAnuncioRemover(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		JavaBeans anuncio = new JavaBeans();
		
		String id = request.getParameter("id");
		anuncio.setIdcon(id);
		
		dao.buscarAnuncioRemover(anuncio); //DAO
		
		request.setAttribute("anuncio", anuncio);
		
		RequestDispatcher rd = request.getRequestDispatcher(""); //Tela de remover
		rd.forward(request, response);
		
	}
